<?xml version="1.0"?>
<robot name="rover" xmlns:xacro="http://wiki.ros.org/xacro">

    <xacro:macro name="wheels"  params="parent">

        <joint name="wheel.003_link_joint" type="continuous">
            <limit effort="500.00000" velocity="200.00000"/>
            <origin rpy="-0.00000 0.00000 0.00000" xyz="-0.75703 -0.70000 -0.20000"/>
            <parent link="stand.0003_link"/>
            <child link="wheel.003_link"/>
            <axis xyz="0.00000 0.00000 1.00000"/>
        </joint>

        <link name="wheel.003_link">
            <collision name="wheel.003_collision">
            <origin rpy="0.00000 0.00000 0.00000" xyz="-0.00297 -0.00000 0.00000"/>
            <geometry>
                <mesh filename="file://$(find rover_description)/meshes/dae/Torus.003.dae" scale="0.30000 0.30000 0.60000"/>
            </geometry>
            </collision>
            <inertial>
